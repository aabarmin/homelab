<VirtualHost *:80>
    <IfModule mod_rewrite.c>
        RewriteEngine On

        RewriteCond %{HTTP:Upgrade} =websocket [NC]
        RewriteRule ^/api/(.*) ws://127.0.0.1:38080/api/$1 [P,L]
    </IfModule>

    ServerName reposilite.barmin-home.local

    ProxyPreserveHost On
    ProxyRequests Off

    ProxyPass / http://127.0.0.1:38080/
    ProxyPassReverse / http://127.0.0.1:38080/

    CustomLog /var/log/apache2/reposilite_access.log combined
    ErrorLog /var/log/apache2/reposilite_error.log
</VirtualHost>