<VirtualHost *:80>
    ServerName jenkins.barmin-home.local

    ProxyPreserveHost On
    ProxyRequests Off

    ProxyPass / http://127.0.0.1:48080/
    ProxyPassReverse / http://127.0.0.1:48080/

    CustomLog /var/log/apache2/jenkins_access.log combined
    ErrorLog /var/log/apache2/jenkins_error.log
</VirtualHost>
